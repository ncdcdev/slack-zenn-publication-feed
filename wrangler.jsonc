{
    "name": "slack-zenn-publication-feed",
    "main": "src/index.ts",
    "compatibility_date": "2024-12-02",
    "observability": {
        "enabled": true,
    },
    "triggers": {
        "crons": ["*/5 * * * *"],
    },
    // 以下はCloudflareダッシュボードで設定する
    // Bindings:
    //   FEED_KV: KV Namespace
    // Variables:
    //   PUBLICATION_NAME: Zenn Publication名
    //   SLACK_WEBHOOK_URL: Slack Incoming Webhook URL (secret)
}
